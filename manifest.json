{
  "manifest_version": 3,
  "name": "Velocity Overlay",
  "version": "1.1",
  "description": "A sleek, minimal, draggable speed test overlay.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "Open Velocity Overlay"
  },
  "background": {
    "service_worker": "background.js"
  }
}